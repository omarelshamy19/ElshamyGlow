{
  "name": "elshamyglow-manager",
  "version": "1.4.0",
  "author": "Elshamy Glow",
  "description": "Elshamy Glow - نظام إدارة المتجر",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux --x64",
    "build:mac": "electron-builder --mac --x64"
  },
  "build": {
    "appId": "com.elshamyglow.store.manager",
    "productName": "Elshamy Glow Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "admin.html",
      "icon.png"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^24.13.3"
  }
}
