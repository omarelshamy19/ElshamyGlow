{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "src/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "src/index.js" },
    { "src": "/admin/?", "dest": "public/admin.html" },
    { "src": "/(.*)", "dest": "public/$1" }
  ]
}
